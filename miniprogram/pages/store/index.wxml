<view class="page">
  <view class="hero">
    <view class="eyebrow">Bar Menu</view>
    <view class="hero-title">酒水点单</view>
    <view class="hero-subtitle">余额支付返积分，积分兑换直接扣减并生成员工出品任务。</view>
  </view>

  <block wx:for="{{products}}" wx:key="_id">
    <view class="product card">
      <image class="cover" src="{{item.image}}" mode="aspectFill" />
      <view class="product-main">
        <view class="name">{{item.name}}</view>
        <view class="desc">{{item.description}}</view>
        <view class="price">{{item.pricePoints}} 积分 / ¥{{item.priceRMB}}</view>
        <button class="secondary-btn" bindtap="addCart" data-product="{{item}}">加入</button>
      </view>
    </view>
  </block>

  <view class="cart card" wx:if="{{cart.length}}">
    <view class="section-title">购物车</view>
    <block wx:for="{{cart}}" wx:key="product._id">
      <view class="cart-row">
        <text>{{item.product.name}} x {{item.quantity}}</text>
        <button bindtap="removeCart" data-id="{{item.product._id}}">-</button>
      </view>
    </block>
    <view class="pay-row">
      <button class="{{paidBy === 'balance' ? 'pay active' : 'pay'}}" bindtap="setPay" data-pay="balance">余额支付</button>
      <button class="{{paidBy === 'points' ? 'pay active' : 'pay'}}" bindtap="setPay" data-pay="points">积分兑换</button>
    </view>
    <button class="primary-btn" bindtap="checkout">确认买单</button>
  </view>
</view>
