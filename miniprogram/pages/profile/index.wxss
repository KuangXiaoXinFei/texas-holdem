.amounts {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin: 24rpx 0;
}

.block {
  margin-top: 24rpx;
}

.picker {
  margin-bottom: 16rpx;
  border-radius: 22rpx;
  background: #f0e4d3;
  padding: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.record {
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: #f6f1e8;
  padding: 18rpx;
  color: #6f6255;
  font-size: 24rpx;
  font-weight: 800;
}

.drink-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eadcc7;
}

.strong {
  font-size: 28rpx;
  font-weight: 900;
}

.drink-row button {
  min-width: 116rpx;
  border-radius: 22rpx;
  background: #7f2b1d;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}
