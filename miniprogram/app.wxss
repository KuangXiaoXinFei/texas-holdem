page {
  background: #f6f1e8;
  color: #2b2521;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero {
  border-radius: 44rpx;
  background: #1a1a1d;
  color: #fff;
  padding: 36rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 50rpx rgba(26, 26, 29, 0.2);
}

.eyebrow {
  color: #f4c46a;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.1;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 26rpx;
  line-height: 1.5;
}

.card {
  border: 1rpx solid #eadcc7;
  border-radius: 32rpx;
  background: #fffaf1;
  padding: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(76, 58, 40, 0.08);
}

.section-title {
  margin-bottom: 22rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 28rpx;
  background: #1a1a1d;
  color: #f4c46a;
  font-size: 28rpx;
  font-weight: 900;
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 24rpx;
  background: #f0e4d3;
  color: #2b2521;
  font-size: 26rpx;
  font-weight: 800;
}

.muted {
  color: #8a7a69;
}
